{
  "name": "qPCR Standard",
  "description": "Standard RDMP for quantitative PCR experiments",
  "roles": [
    {
      "name": "PI",
      "permissions": {
        "can_edit_metadata": true,
        "can_edit_paths": true,
        "can_create_release": true,
        "can_manage_rdmp": true
      }
    },
    {
      "name": "researcher",
      "permissions": {
        "can_edit_metadata": true,
        "can_edit_paths": true,
        "can_create_release": false,
        "can_manage_rdmp": false
      }
    },
    {
      "name": "viewer",
      "permissions": {
        "can_edit_metadata": false,
        "can_edit_paths": false,
        "can_create_release": false,
        "can_manage_rdmp": false
      }
    }
  ],
  "fields": [
    {
      "key": "genotype",
      "label": "Genotype",
      "type": "string",
      "required": true,
      "description": "Genetic background of the sample (e.g. wildtype, knockout).",
      "visibility": "collaborators"
    },
    {
      "key": "treatment",
      "label": "Treatment",
      "type": "string",
      "required": true,
      "description": "Experimental condition applied to the sample (e.g. vehicle, doxorubicin).",
      "visibility": "collaborators"
    }
  ],
  "ingestion_rules": {
    "file_patterns": ["*.csv", "*.xlsx"]
  },
  "ingest": {
    "measured_samples_mode": "multi",
    "multi": {
      "annotation_key": "observation",
      "index_fields": ["position", "target"],
      "run_fields": [
        {"key": "primer_batch", "label": "Primer batch", "type": "string", "required": true}
      ]
    }
  }
}
